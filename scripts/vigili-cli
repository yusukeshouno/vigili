#!/usr/bin/env bash
# vigili-cli — packages/daemon/dist/sentinel-cli.js への薄い launcher。
# 引数はそのまま透過する。
# (binary file はまだ sentinel-cli.js のまま、リブランド過渡期)

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -h "${SOURCE}" ]; do
  DIR="$(cd -P "$(dirname "${SOURCE}")" && pwd)"
  SOURCE="$(readlink "${SOURCE}")"
  [[ "${SOURCE}" != /* ]] && SOURCE="${DIR}/${SOURCE}"
done
SCRIPT_DIR="$(cd -P "$(dirname "${SOURCE}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
CLI_JS="${REPO_ROOT}/packages/daemon/dist/sentinel-cli.js"

if [[ ! -f "${CLI_JS}" ]]; then
  echo "vigili-cli: ${CLI_JS} が見つかりません。先に \`pnpm --filter @vigili/daemon build\` を実行してください。" >&2
  exit 1
fi

exec node "${CLI_JS}" "$@"
